# ════════════════════════════════════════════════════════
#  KAN RL Environment — Configuration
#  cp .env.example .env  →  edit this file only
# ════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────
GROQ_API_KEY=xxxx


# ── Model (change only this line to switch models) ───────
# Cost-effective for testing:
#   llama-3.1-8b-instant       $0.05/1M in  — fast, cheap, weaker code
#   gemma2-9b-it               $0.20/1M in  — decent quality
#   mixtral-8x7b-32768         $0.24/1M in  — good balance
# Best quality:
#   llama-3.3-70b-versatile    $0.59/1M in  — recommended for production
#   llama-3.1-70b-versatile    $0.59/1M in  — alternative 70b
GROQ_MODEL=llama-3.1-8b-instant

# ── Agent tuning ─────────────────────────────────────────
# Number of agent iterations (3-4 for 70b, 5-6 for 8b)
MAX_ITERATIONS=2

# Max tokens per LLM response (reduce for 8b to avoid truncation)
# 70b: 4096  |  8b: 2048
#MAX_TOKENS=4096
MAX_TOKENS=2048
